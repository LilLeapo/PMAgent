# Feishu App credentials
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
# FEISHU_BASE_URL=https://open.feishu.cn  # 默认飞书，海外用 https://open.larksuite.com

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=https://your-proxy.com/v1  # 自定义代理地址
# LLM_MODEL=claude-sonnet-4-20250514  # 可换模型

# Bitable
BITABLE_APP_TOKEN=xxxxx

# Bot config
BOT_NAME=PMBot
LOG_LEVEL=info

# Notification defaults
STANDUP_CRON=0 10 * * 1-5
RISK_REVIEW_CRON=0 10 * * 1
STALE_TASK_DAYS=3
BLOCKED_TASK_HOURS=24
